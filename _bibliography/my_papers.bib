@Comment{
al-folio 支持很多额外字段，不只是标准 BibTeX。常用的是这些：
inproceedings{luo2025example,
  title={Example Paper Title},
  author={Luo, Canhui and Zhang, Qingyun and Su, Zhouxing and L{\"u}, Zhipeng},
  booktitle={Proceedings of Example Conference},
  year={2025},

  abbr={AAAI},
  selected={true},
  bibtex_show={true},
  abstract={这里可以写摘要，页面上会出现 Abs 按钮。},
  doi={10.xxxx/example},
  arxiv={2501.00000},
  pdf={example-paper.pdf},
  code={https://github.com/lxily/example},
  website={https://example.com},
  slides={example-slides.pdf},
  poster={example-poster.pdf},
  preview={example-preview.png},
  award={Best Paper Award},
  award_name={Award}
}

selected={true}：出现在首页精选发表物
bibtex_show={true}：显示 Bib 按钮
abstract={...}：显示 Abs 按钮
doi={...}：显示 DOI 按钮
arxiv={...}：显示 arXiv 按钮
pdf={xxx.pdf}：显示 PDF 按钮，文件放到 assets/pdf/xxx.pdf
slides={xxx.pdf}：显示 Slides 按钮，文件也放到 assets/pdf/
poster={xxx.pdf}：显示 Poster 按钮，文件也放到 assets/pdf/
code={https://...}：显示 Code 按钮
website={https://...}：显示 Website 按钮
preview={xxx.png}：显示论文缩略图，文件放到 assets/img/publication_preview/xxx.png
abbr={AAAI}：显示会议/期刊缩写徽章
award={...}：显示获奖信息
award_name={...}：控制奖项按钮文字
}

